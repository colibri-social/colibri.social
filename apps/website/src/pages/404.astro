---
import PublicLayout from "@/layouts/PublicLayout.astro";
---

<PublicLayout
	title="Page Not Found"
	description="We were unable to find the page you're looking for."
>
	<section
		class="py-40 mx-auto w-full max-w-336 md:px-16 px-6 relative flex flex-col items-center gap-12 h-screen justify-center"
	>
		<div class="flex flex-col gap-4 items-center text-center">
			<small class="text-primary text-sm">Whoops.</small>
			<h1 class="reset h-fit leading-56 text-[192px] font-black m-0">404</h1>
			<p class="m-0 text-muted-foreground">
				We were unable to find the page you're looking for. Try one of these
				links:
			</p>
		</div>
		<div
			class="flex flex-row items-center justify-center text-muted-foreground w-full max-w-xl gap-4 text-lg"
		>
			<a href="/" class="hover:underline">Home</a>
			<span class="w-1 h-1 rounded-full bg-muted-foreground"></span>
			<a href="/app" class="hover:underline">Web-App</a>
			<span class="w-1 h-1 rounded-full bg-muted-foreground"></span>
			<a href="/faq" class="hover:underline">FAQ</a>
		</div>
	</section>
</PublicLayout>
