---
import type { ParamInfo } from "./XRPCEndpointCard.astro";

type Props = ParamInfo & {
	key: string;
	level?: number;
};

const { key, type, required, children, level } = Astro.props;
---


<div class="flex flex-row items-center gap-4">
	<span class="font-medium whitespace-nowrap">{key} <small class="text-neutral-500">({type})</small></span>
	{required && (
		<div class="w-full h-px border-b border-dashed border-(--sl-color-gray-5)"></div>
		<span class="font-medium text-red-400">Required</span>
	)}
</div>
{children && (
	<div class="flex flex-col gap-2 border-l border-(--sl-color-gray-5)" style={`padding-left: ${16 + (level || 0)}px`}>
		{Object.keys(children).map((key) => (
			<Astro.self {...children[key]} key={key} />
		))}
	</div>
)}
