---
import { Font } from "astro:assets";
import Footer from "@/components/public/Footer.astro";
import Navbar from "@/components/public/Navbar.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
	home?: boolean;
}

const { home } = Astro.props;
---

<BaseLayout {home}>
	<Fragment slot="head">
		<Font cssVariable="--font-stardom" preload />
	</Fragment>
	<Navbar />
	<main class="min-h-screen overflow-x-hidden z-20 relative">
		<slot />
	</main>
	<Footer />
</BaseLayout>
