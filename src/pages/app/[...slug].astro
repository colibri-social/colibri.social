---
import { Agent } from "@atproto/api";
import { client } from "@/utils/atproto/oauth";
import { ColibriSDK, type CommunityData } from "@/utils/sdk";
import { App } from "../../components/solid/App.tsx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "@/styles/emoji-picker.css";

const user = await Astro.session?.get("user");

let communities: Array<CommunityData> = [];

if (user) {
	try {
		const oauthSession = await client.restore(user.sub!);
		const agent = new Agent(oauthSession);
		const sdk = new ColibriSDK(agent);

		const data = await sdk.getCommunities(agent.did!);

		communities = data;
	} catch (e) {
		console.error(e);
		// TODO: Refresh instead
		return Astro.redirect("/auth/logout");
	}
} else {
	return Astro.redirect("/login");
}
---

<BaseLayout title="Colibri">
	<App {communities} {user} client:only="solid-js" />
</BaseLayout>
