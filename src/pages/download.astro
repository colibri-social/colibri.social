---
import PublicLayout from "@/layouts/PublicLayout.astro";
---

<PublicLayout>
	<section
		class="py-40 mx-auto w-full max-w-336 px-16 relative flex flex-col items-center gap-8"
	>
		<div class="flex flex-col gap-4 items-center text-center">
			<small class="text-primary text-sm">
				On your desktop, in your pocket.
			</small>
			<h1 class="text-5xl font-black m-0">DOWNLOAD</h1>
			<p class="m-0 text-muted-foreground">
				Get the Colibri app for your favorite devices and go for a flight.
			</p>
		</div>
		<div
			class="mx-8 mb-0 w-full border-none h-px bg-border relative prose prose-neutral dark:prose-invert"
		>
		</div>
		<h2>TODO</h2>
	</section>
</PublicLayout>
<style is:global>
	h2:first-of-type {
		margin-top: 0;
	}
</style>
